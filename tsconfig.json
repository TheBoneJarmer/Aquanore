{
  "include": [
    "src/aquanore/*",
    "src/aquanore/audio/*",
    "src/aquanore/graphics/*",
    "src/aquanore/input/*",
    "src/aquanore/loaders/*",
    "src/aquanore/math/*",
  ],
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "declarationMap": true,
    "removeComments": true,
    "lib": ["ESNext"]
  }
}