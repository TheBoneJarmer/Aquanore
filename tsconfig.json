{
  "include": [
    "src/aquanore/"
  ],
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": false,
    "rootDir": "./src/aquanore",
    "outDir": "dist",
    "removeComments": true,
    "strictPropertyInitialization": false,
    "lib": [
      "ESNext",
      "DOM"
    ]
  }
}