{
  "include": [
    "src/aquanore/*",
    "src/aquanore/audio/*",
    "src/aquanore/graphics/*",
    "src/aquanore/input/*",
    "src/aquanore/loaders/*",
    "src/aquanore/math/*",
    "src/aquanore/interfaces/*"
  ],
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": false,
    "rootDir": "./src",
    "outDir": "dist",
    "declarationMap": true,
    "removeComments": true,
    "strictPropertyInitialization": false,
    "lib": [
      "ESNext",
      "DOM"
    ]
  }
}